# EFFOI Restaurant Environment Variables

# Production Configuration
DATABASE_URL=postgresql://username:password@host:port/database
SECRET_KEY=your-secret-key-here-at-least-32-characters-long
ADMIN_PASSWORD=your-strong-admin-password
FLASK_ENV=production
BASE_URL=https://www.effoirestaurant.com

# Development (for local testing)
# DATABASE_URL=sqlite:///instance/effoi.db
# FLASK_ENV=development

# Email Configuration (optional - for sending notifications)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
ADMIN_EMAIL=admin@effoirestaurant.com

# Render Specific (automatically set by Render)
# PORT=5000
# RENDER=true
